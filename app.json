{
  "expo": {
    "name": "Deenify",
    "slug": "deenify-app",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "deenifyapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#07C589",
      "resizeMode": "contain"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/Deenify (1).png",
      "splash": {
        "backgroundColor": "#07C589",
        "resizeMode": "contain"
      },
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to provide accurate prayer times for your area.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location to provide accurate prayer times for your area.",
        "NSUserNotificationsUsageDescription": "This app needs permission to send prayer time notifications to remind you when it's time to pray.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save screenshots to your photo library.",
        "NSPhotoLibraryUsageDescription": "This app needs permission to access your photo library.",
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "bundleIdentifier": "com.suhelislam.deenifyapp"
    },
    "android": {
      "splash": {
        "backgroundColor": "#07C589",
        "resizeMode": "contain"
      },
      "adaptiveIcon": {
        "backgroundColor": "#3a5a40",
        "foregroundImage": "./assets/images/Deenify (1).png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/Deenify (1).png"
      },
      "notification": {
        "icon": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.suhelislam.deenifyapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#3a5a40"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to save screenshots.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save screenshots to your photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2696ff0-21a8-4d40-bd77-3eb9e84a53d8"
      }
    }
  }
}